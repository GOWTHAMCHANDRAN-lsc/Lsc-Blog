{
  "root": true,
  "ignorePatterns": ["**/node_modules/**", "**/.next/**", "**/coverage/**"],
  "plugins": ["prettier"],
  "extends": ["eslint:recommended"],
  "overrides": [
    {
      "files": ["*.js", "*.cjs", "*.mjs"],
      "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
      },
      "env": {
        "node": true,
        "es2022": true
      },
      "extends": ["eslint:recommended"],
      "rules": {
        "prettier/prettier": "error",
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
        "no-console": "warn"
      }
    }
  ]
}
